{
  "name": "tile-generator",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {},
  "scripts": {
    "add-app-engine": "npm install --workspace=@tile-generator/app-engine",
    "add-client": "npm install --workspace=@tile-generator/react-app",
    "add-common": "npm install --workspace=@tile-generator/common",
    "add-server": "npm install --workspace=@tile-generator/server",
    "build-client-prod": "npm install && npm run build-common && npm run build-client",
    "build-client": "lerna run build --scope=@tile-generator/react-app",
    "build-common": "lerna run build --scope=@tile-generator/common",
    "build-server": "lerna run build --scope=@tile-generator/server",
    "build": "lerna run build",
    "clean": "lerna run clean",
    "db:create": "sh ./scripts/create_db.sh",
    "pub": "lerna publish",
    "reinstall-common": "./scripts/reinstall_common.sh"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "devDependencies": {
    "lerna": "^8.2.4"
  }
}
